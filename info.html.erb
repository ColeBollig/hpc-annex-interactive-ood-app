<%
  # condor_version: read from annex_info.json, written once at submit time
  # by submit.yml.erb (a static tarball read is authoritative for VERSION,
  # see that file's comment for why).
  #
  # `staged_root` here is an undocumented-for-info.html.erb but
  # confirmed-working local variable OOD injects into this binding --
  # community-verified (osc.github.io/ood-documentation is silent on it for
  # this specific file; see https://discourse.openondemand.org/t/customizing-interactive-app-cards-using-erb/2694
  # for a working example). Wrapped in rescue since it's not an officially
  # guaranteed API and could break on a future OOD version -- this card
  # section should just quietly not render rather than break the whole card.
  require "json"

  info = begin
    path = File.join(staged_root, "annex_info.json")
    File.exist?(path) ? JSON.parse(File.read(path)) : {}
  rescue StandardError => e
    warn "[htc-annex-app] info.html.erb: failed to read annex_info.json: #{e.class}: #{e.message}"
    {}
  end

  # AnnexPilotConfig resolves the pilot's actual effective
  # STARTD_NOCLAIM_SHUTDOWN from plain-text config fragments already on
  # disk -- see lib/annex_pilot_config.rb for the full explanation. Loaded
  # from staged_root (copied there by submit.yml.erb) rather than
  # `require`d via __dir__ -- __dir__ doesn't reliably resolve inside this
  # file's own OOD rendering path (confirmed by a real production LoadError
  # -- BatchConnect::Session#render_info_view renders info.html.erb
  # differently than BatchConnect::App#render_erb_file renders
  # form.yml.erb/submit.yml.erb, where __dir__ is fine).
  #
  # Rescues StandardError AND ScriptError (LoadError's actual superclass --
  # NOT a StandardError, so `rescue StandardError` alone would silently
  # fail to catch a bad `load`) so a failure here just falls back to the
  # static warning rather than breaking the whole card. Logged via `warn`
  # (STDERR) rather than swallowed outright -- a silent rescue here is
  # exactly what turned the original `__dir__` LoadError into a multi-day
  # investigation instead of a one-line log read (see git history).
  shutdown_warning = begin
    load(File.join(staged_root, "annex_pilot_config.rb"))
    AnnexPilotConfig.shutdown_warning(staged_root)
  rescue StandardError, ScriptError => e
    warn "[htc-annex-app] info.html.erb: failed to resolve shutdown warning: #{e.class}: #{e.message}"
    "Pilot may exit early after a set amount of time without any job pressure. See configured <code>STARTD_NOCLAIM_SHUTDOWN</code> value."
  end
%>
<% if info["condor_version"] %>
  <p><strong>Detected HTCondor version:</strong> <%= info["condor_version"] %></p>
<% end %>
<div class="alert alert-warning">
  <%= shutdown_warning %>
</div>
