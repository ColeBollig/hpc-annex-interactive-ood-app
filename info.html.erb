<%
  # condor_version: read from annex_info.json, written once at submit time
  # by submit.yml.erb (a static tarball read is authoritative for VERSION,
  # see that file's comment for why).
  #
  # STARTD_NOCLAIM_SHUTDOWN: queried LIVE, on every render of this card,
  # straight from the pilot's own downloaded HTCondor install via
  # lib/annex_pilot.rb -- see that file for why a static read can't be
  # trusted for this one. Returns nil gracefully if the pilot doesn't exist
  # yet, never did, or isn't executable from the OOD web server (e.g. a
  # different OS/arch than the compute node it was downloaded on).
  #
  # NOTE: __dir__ does NOT reliably resolve to this app's directory in this
  # file specifically (confirmed by a real production LoadError --
  # BatchConnect::Session#render_info_view renders info.html.erb
  # differently than BatchConnect::App#render_erb_file renders
  # form.yml.erb/submit.yml.erb, where __dir__ is fine). So `app_dir` is
  # read from annex_info.json (written by submit.yml.erb, where __dir__ IS
  # reliable) instead of computed here.
  #
  # `staged_root` here is an undocumented-for-info.html.erb but
  # confirmed-working local variable OOD injects into this binding --
  # community-verified (osc.github.io/ood-documentation is silent on it for
  # this specific file; see https://discourse.openondemand.org/t/customizing-interactive-app-cards-using-erb/2694
  # for a working example). Wrapped in rescue since it's not an officially
  # guaranteed API and could break on a future OOD version -- this card
  # section should just quietly not render rather than break the whole card.
  require "json"

  info = begin
    path = File.join(staged_root, "annex_info.json")
    File.exist?(path) ? JSON.parse(File.read(path)) : {}
  rescue StandardError
    {}
  end

  # Isolated in its own rescue (separate from `info` above) so a failure to
  # locate/require/run AnnexPilot never takes down the condor_version
  # display too -- each piece of card info degrades independently.
  #
  # Rescues StandardError AND ScriptError (LoadError's actual superclass --
  # NOT a StandardError, so `rescue StandardError` alone silently fails to
  # catch a bad `require`, exactly the crash this whole indirection exists
  # to prevent; caught the hard way via testing before this ever shipped).
  shutdown_seconds = begin
    app_dir = info["app_dir"]
    if app_dir && !app_dir.to_s.empty?
      require File.join(app_dir, "lib", "annex_pilot.rb")
      raw = AnnexPilot.condor_config_val(staged_root, "STARTD_NOCLAIM_SHUTDOWN")
      raw&.match?(/\A\d+\z/) ? raw.to_i : nil
    end
  rescue StandardError, ScriptError
    nil
  end
%>
<% if info["condor_version"] %>
  <p>Detected HTCondor version: <strong><%= info["condor_version"] %></strong></p>
<% end %>
<% if shutdown_seconds %>
  <% minutes_raw = (shutdown_seconds / 60.0).round(1) %>
  <% minutes = minutes_raw == minutes_raw.to_i ? minutes_raw.to_i : minutes_raw %>
  <div class="alert alert-warning">
    This job may go away in <%= minutes %> minutes if there's no job pressure
    (the execute point shuts down after <%= shutdown_seconds %> seconds unclaimed).
  </div>
<% end %>

