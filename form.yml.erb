---
cluster: "*"

<%
  require File.join(__dir__, "lib", "annex_defaults.rb")

  resources = AnnexDefaults.resolve_all
  email_supported = AnnexDefaults.email_supported?
%>

form:
  - cluster
  - annex_tarball_path
  - auto_queues
  - num_cores
  - memory_gb
  - num_gpus
  - bc_num_hours
  - bc_account
  - send_email
  - user_email


attributes:
  # Slurm account to charge for resource usage
  bc_account:
    label: "Account"
    help: "Slurm account to charge for this job. Leave blank to use your default account."

  # Desired number of cores per node to make available via pilot
  num_cores:
    widget: "number_field"
    label: "CPUs per Node"
    help: "Number of CPU cores per node to advertise to HTCondor jobs."
    value: <%= resources[:num_cores][:default] %>
    min: <%= resources[:num_cores][:min] %>
    max: <%= resources[:num_cores][:max] %>
    step: 1

  # Desired amount of memory (GB) per node to make available via pilot
  memory_gb:
    widget: "number_field"
    label: "Memory per Node (GB)"
    help: "Amount of memory per node (in GB) to advertise to HTCondor jobs."
    value: <%= resources[:memory_gb][:default] %>
    min: <%= resources[:memory_gb][:min] %>
    max: <%= resources[:memory_gb][:max] %>
    step: 1

  # Desired number of GPUs per node to make available via pilot
  num_gpus:
    widget: "number_field"
    label: "GPUs per Node"
    help: "Number of GPUs per node to advertise to HTCondor jobs. Set to 0 for no GPUs."
    value: <%= resources[:num_gpus][:default] %>
    min: <%= resources[:num_gpus][:min] %>
    max: <%= resources[:num_gpus][:max] %>
    step: 1

  # Maximum pilot job runtime (in hours)
  bc_num_hours:
    label: "Max Wall Time (hours)"
    help: "Maximum time the annex will run. HTCondor EPs will begin shutting down 5 minutes before this limit."
    value: <%= resources[:num_hours][:default] %>
    min: <%= resources[:num_hours][:min] %>
    max: <%= resources[:num_hours][:max] %>
    step: 1

  # Email user on job start and end. Always kept in the form list (as
  # hidden_field when unsupported) rather than conditionally omitted, so
  # submit.yml.erb can always rely on these attributes existing in context
  # instead of guessing whether OOD's context object safely no-ops on a
  # reference to an attribute that was never part of the form.
  send_email:
    widget: "<%= email_supported ? 'check_box' : 'hidden_field' %>"
    label: "Email notifications"
    help: "Send an email notification when the job starts and when it finishes or is cancelled."
    value: 0
    html_options:
      data:
        hide-user-email-when-un-checked: true

  # Email address to send notifications
  user_email:
    widget: "<%= email_supported ? 'email_field' : 'hidden_field' %>"
    label: "Email Address"
    help: "Email address for job notifications."
    placeholder: "you@example.com"
    value: ""

  # Path to the annex-setup.tar produced by `htcondor annex create`
  annex_tarball_path:
    display: true
    required: true
    widget: "path_selector"
    label: "Annex source tarball"
    help: "Path to the tarball produced by `htcondor annex create` on the access point (e.g. `~/my-annex.tar`)."
    directory: "<%= CurrentUser.home %>"
    popup_title: "Select annex source tarball"
